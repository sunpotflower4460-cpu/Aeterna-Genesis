{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "aeternagenesis",
  "compatibility_date": "2026-07-11",
  "observability": {
    "enabled": true
  },
  "build": {
    "command": "npm ci && npm run build",
    "cwd": "app"
  },
  "assets": {
    "directory": "app/dist"
  },
  "compatibility_flags": [
    "nodejs_compat"
  ]
}
