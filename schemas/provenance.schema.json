{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://aeterna-genesis/schemas/provenance.schema.json",
  "title": "Genesis Provenance (provenance.yaml)",
  "description": "各 entity/state_variable がどこから来たかを記録する。ANTI_DRIFT の上流拡張（docs/GENESIS_PROVENANCE.md）。創発と呼べるのは emerged だけ。環境条件には claim_excludes を必ず付す。",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema_version", "entries"],
  "properties": {
    "schema_version": {"type": "integer", "minimum": 1},
    "entries": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["name", "input_class", "manually_set", "outcome_targeted"],
        "properties": {
          "name": {"type": "string", "minLength": 1, "description": "entity または state_variable 名"},
          "input_class": {"type": "string", "enum": ["fundamental_relation", "prepared_state", "environmental_condition", "emerged_state"], "description": "入力4分類（docs/GENESIS_PROVENANCE.md）"},
          "manually_set": {"type": "boolean", "description": "直接置いたか（true）／過程・親から生成したか（false）"},
          "source": {"type": "string", "enum": ["law", "parent_room", "preparation_result", "environmental_model"], "description": "生成元（manually_set=false のとき）"},
          "outcome_targeted": {"type": "boolean", "const": false, "description": "結果を先取りしていないこと（常に false／true は第8監査違反）"},
          "claim_excludes": {"type": "array", "items": {"type": "string"}, "description": "environmental_condition が主張から除外する現象（例 spontaneous_temperature_gradient）"}
        },
        "allOf": [
          {"if": {"properties": {"input_class": {"const": "environmental_condition"}}}, "then": {"required": ["claim_excludes"]}},
          {"if": {"properties": {"input_class": {"const": "emerged_state"}}}, "then": {"properties": {"manually_set": {"const": false}}}}
        ]
      }
    }
  }
}
